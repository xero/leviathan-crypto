{
	"name": "leviathan-crypto",
	"version": "2.1.0",
	"author": "xero (https://x-e.ro)",
	"license": "MIT",
	"description": "Post-quantum WASM cryptography library with paranoid ciphers (Serpent-256, XChaCha20-Poly1305), ML-KEM, and forward-secret ratcheting. Zero dependencies. Constant-time verified and strictly typed.",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": "./dist/index.js",
		"./stream": "./dist/stream/index.js",
		"./serpent": "./dist/serpent/index.js",
		"./serpent/embedded": "./dist/serpent/embedded.js",
		"./chacha20": "./dist/chacha20/index.js",
		"./chacha20/embedded": "./dist/chacha20/embedded.js",
		"./sha2": "./dist/sha2/index.js",
		"./sha2/embedded": "./dist/sha2/embedded.js",
		"./sha3": "./dist/sha3/index.js",
		"./sha3/embedded": "./dist/sha3/embedded.js",
		"./keccak": "./dist/keccak/index.js",
		"./keccak/embedded": "./dist/keccak/embedded.js",
		"./kyber": "./dist/kyber/index.js",
		"./kyber/embedded": "./dist/kyber/embedded.js",
		"./aes": "./dist/aes/index.js",
		"./aes/embedded": "./dist/aes/embedded.js",
		"./mldsa": "./dist/mldsa/index.js",
		"./mldsa/embedded": "./dist/mldsa/embedded.js",
		"./ratchet": "./dist/ratchet/index.js"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"SECURITY.md",
		"CLAUDE.md"
	],
	"scripts": {
		"prepack": "bun scripts/pack.ts --pre",
		"postpack": "bun scripts/pack.ts --post",
		"build": "bun scripts/build.ts",
		"test": "bun scripts/test.ts",
		"lint": "bun scripts/lint.ts",
		"pin-actions": "bun scripts/pin-actions.ts",
		"_shorthand": "# bake=build · check=full(build+lint+unit+e2e) · fix=lint --fix · pin=pin-actions · unit/e2e accept files: bun unit test/unit/foo.test.ts · group: bun run test unit:group <name>",
		"bake": "bun run build",
		"fix": "bun scripts/lint.ts --fix",
		"check": "bun scripts/check.ts",
		"unit": "bun run test unit",
		"e2e": "bun run test e2e",
		"pin": "bun run pin-actions"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@types/bun": "^1.3.13",
		"@types/node": "^25.6.2",
		"@vitest/web-worker": "^3.2.4",
		"assemblyscript": "^0.27.37",
		"esbuild": "^0.28.0",
		"eslint": "^10.3.0",
		"jiti": "^2.7.0",
		"pin-github-action": "^3.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.3",
		"vitest": "^3.2.4"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xero/leviathan-crypto.git"
	},
	"homepage": "https://leviathan.3xi.club",
	"bugs": {
		"url": "https://github.com/xero/leviathan-crypto/issues"
	},
