		"mldsa",
		"pqc",
		"post-quantum",
		"key-encapsulation",
		"double-ratchet",
		"ratchet",
		"forward-secrecy",
		"spqr",
		"sha",
		"sha-256",
		"sha-512",
		"sha-3",
		"keccak",
		"shake",
		"cshake",
		"hmac",
